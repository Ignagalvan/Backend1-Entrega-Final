<h1>Catálogo de productos</h1>

{{#if products.length}}
<ul>
    {{#each products}}
    <li>
        <b>{{this.title}}</b> - ${{this.price}} (ID: {{this.id}})
    </li>
    {{/each}}
</ul>
{{else}}
<p>No hay productos cargados.</p>
{{/if}}

<a href="/realtimeproducts">Ver catálogo en tiempo real</a>